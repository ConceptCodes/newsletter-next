AUTH_SECRET=""
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

DATABASE_URL="postgresql://postgres:password@localhost:5432/newsletter"

TOTP_SECRET=""
ADMIN_EMAIL="admin@example.com"

SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Secret that authenticates Vercel Cron requests and the "Generate" button.
CRON_SECRET=""

# Vercel AI Gateway — one key powers every model + hosted web search.
# Get one at https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=""

# The niche this newsletter covers. The agent researches current news here.
AGENT_NICHE="AI engineering, LLM tooling, and developer infrastructure"

# `creator/model` id — see https://vercel.com/ai-gateway/models
AGENT_MODEL="anthropic/claude-sonnet-4-5"
AGENT_TONE="witty, concise, and technically precise"
AGENT_AUDIENCE="software engineers and founders"
AGENT_MAX_REVISIONS="3"
AGENT_SCORE_THRESHOLD="8"

NEXT_PUBLIC_APP_NAME="Newsletter"
NEXT_PUBLIC_APP_URL="https://your-newsletter.vercel.app"

# Workflow DevKit — Local World storage dir (dev/local build only; ignored on
# Vercel, which auto-uses the Vercel World).
WORKFLOW_LOCAL_DATA_DIR=".workflow-data"
