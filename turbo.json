{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "stream",
  "globalDependencies": ["tsconfig.base.json", ".env.example"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "app/.well-known/workflow/**"],
      "env": [
        "DATABASE_URL",
        "AUTH_SECRET",
        "TOTP_SECRET",
        "ADMIN_EMAIL",
        "SMTP_HOST",
        "SMTP_PORT",
        "SMTP_USER",
        "SMTP_PASS",
        "SMTP_FROM",
        "NODE_ENV",
        "NEXT_PUBLIC_APP_NAME",
        "CRON_SECRET",
        "AI_GATEWAY_API_KEY",
        "AGENT_NICHE",
        "AGENT_MODEL",
        "AGENT_TONE",
        "AGENT_AUDIENCE",
        "AGENT_MAX_REVISIONS",
        "AGENT_SCORE_THRESHOLD",
        "WORKFLOW_LOCAL_DATA_DIR"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck", "build"],
      "outputs": []
    }
  }
}
