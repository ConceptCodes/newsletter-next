{
  "name": "newsletter",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@hookform/resolvers": "^4.1.0",
      "@radix-ui/react-label": "^2.1.2",
      "@radix-ui/react-slot": "^1.1.2",
      "@radix-ui/react-tabs": "^1.1.3",
      "@radix-ui/react-toast": "^1.2.6",
      "@tanstack/react-query": "^5.50.0",
      "@tanstack/react-table": "^8.21.2",
      "@trpc/client": "^11.0.0-rc.446",
      "@trpc/next": "^11.0.0-rc.446",
      "@trpc/react-query": "^11.0.0-rc.446",
      "@trpc/server": "^11.0.0-rc.446",
      "@types/node": "^20.14.10",
      "@types/react": "^18.3.3",
      "@types/react-dom": "^18.3.0",
      "class-variance-authority": "^0.7.1",
      "clsx": "^2.1.1",
      "date-fns": "^4.1.0",
      "drizzle-orm": "^0.33.0",
      "input-otp": "^1.4.2",
      "lucide-react": "^0.475.0",
      "next": "^16.0.0",
      "react": "^18.3.1",
      "react-dom": "^18.3.1",
      "react-hook-form": "^7.54.2",
      "superjson": "^2.2.1",
      "tailwind-merge": "^3.0.1",
      "tailwindcss": "^3.4.3",
      "typescript": "^5.5.3",
      "zod": "^3.24.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev --filter=@newsletter/web",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "bun run format:check && turbo run lint typecheck build",
    "db:generate": "turbo run db:generate --filter=@newsletter/db",
    "db:migrate": "turbo run db:migrate --filter=@newsletter/db",
    "db:push": "turbo run db:push --filter=@newsletter/db",
    "db:studio": "turbo run db:studio --filter=@newsletter/db"
  },
  "devDependencies": {
    "oxfmt": "^0.56.0",
    "oxlint": "^1.0.0",
    "postcss": "^8.4.39",
    "tailwindcss-animate": "^1.0.7",
    "turbo": "^2.0.0",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.6"
}
